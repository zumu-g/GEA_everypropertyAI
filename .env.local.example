# ─── Required ────────────────────────────────────────────────────────────────

# Firecrawl — web scraping engine
# Get key at https://firecrawl.dev
FIRECRAWL_API_KEY=

# ─── LLM Extraction (pick one) ──────────────────────────────────────────────

# Option 1: OpenRouter (recommended — cheap, 300+ models)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model choices:
#   moonshotai/kimi-k2              — Kimi K2 (~$0.60/M tokens, good at extraction)
#   deepseek/deepseek-chat-v3-0324  — DeepSeek V3 (~$0.27/M tokens)
#   google/gemini-2.5-flash         — Gemini Flash (~$0.15/M tokens, fastest)
#   meta-llama/llama-4-maverick     — Llama 4 (~$0.50/M tokens)
#   anthropic/claude-sonnet-4       — Claude via OpenRouter (~$3/M tokens)
OPENROUTER_MODEL=moonshotai/kimi-k2

# Option 2: Direct Anthropic (more expensive, best quality)
ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Supabase — persistent database (app works without, uses in-memory cache)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps — address autocomplete (has free REA fallback)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cron — auth token for daily listing crawler endpoint
CRON_SECRET=
